<?xml version="1.0" encoding="UTF-8" ?>
<CycloneDDS>
    <Domain Id="any">
        <!--
            CycloneDDS 共享内存传输配置
            RouDi 随 roslaunch 自动启动
        -->
        <SharedMemory>
            <Enable>true</Enable>
            <LogLevel>error</LogLevel>
        </SharedMemory>
        <General>
            <Interfaces>
                <NetworkInterface name="lo" multicast="default" />
            </Interfaces>
            <AllowMulticast>true</AllowMulticast>
        </General>
        <Discovery>
            <EnableTopicDiscoveryEndpoints>true</EnableTopicDiscoveryEndpoints>
        </Discovery>
        <!-- <Tracing> -->
            <!-- <Verbosity>config</Verbosity> -->
            <!-- <OutputFile>cdds.log.${CYCLONEDDS_PID}</OutputFile> -->
            <!-- <OutputFile>stderr</OutputFile> -->
        <!-- </Tracing> -->
    </Domain>
</CycloneDDS>
