        <!-- 头部关节 -->
        <joint><name>zhead_1_joint</name></joint>
        <joint><name>zhead_2_joint</name></joint>
      </joints>
      
      <!-- 接触传感器配置 -->
      <contacts>
        <contact><link>ll_foot_toe</link></contact>
        <contact><link>ll_foot_heel</link></contact>
        <contact><link>lr_foot_toe</link></contact>
        <contact><link>lr_foot_heel</link></contact>
        <contact><link>rl_foot_toe</link></contact>
        <contact><link>rl_foot_heel</link></contact>
        <contact><link>rr_foot_toe</link></contact>
        <contact><link>rr_foot_heel</link></contact>
      </contacts>
      </plugin>
  </gazebo>
</robot>

